// Banan — patisserie ordering platform
// Prisma schema. Run `pnpm prisma migrate dev` to apply changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  MERCHANT_OWNER
  MERCHANT_STAFF
  KITCHEN_MANAGER
  KITCHEN_STAFF
  ADMIN
}

enum MembershipTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  phone          String?        @unique
  passwordHash   String
  fullName       String
  avatarUrl      String?
  role           Role           @default(CUSTOMER)
  // Disabled accounts cannot log in (soft-delete / suspension by admin).
  isActive       Boolean        @default(true)
  /// True once the owner proved control of the account (self-registered or
  /// completed a password reset). Guest-checkout / merchant-created stubs stay
  /// false. Guard: an unauthenticated guest order whose phone matches a
  /// CLAIMED account is refused (must log in) so it can't hijack a real user.
  claimed        Boolean        @default(false)
  // Loyalty (denormalized current balance; LoyaltyEvent is the source of truth)
  membershipTier MembershipTier @default(BRONZE)
  pointsBalance  Int            @default(0)
  birthday       DateTime?      @db.Date
  gender         Gender?

  // Notification preferences (customer self-service opt-out).
  marketingOptIn    Boolean @default(true)
  orderUpdatesOptIn Boolean @default(true)

  // Merchant-only CRM: private staff notes + tags (VIP, allergy, …).
  merchantNotes String?
  merchantTags  String[] @default([])

  // Staff linkage — null for customers.
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  kitchenId String?
  kitchen   Kitchen? @relation(fields: [kitchenId], references: [id])

  addresses         Address[]
  paymentMethods    PaymentMethod[]
  orders            Order[]            @relation("CustomerOrders")
  loyaltyEvents     LoyaltyEvent[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  emailChanges      EmailChange[]
  couponRedemptions CouponRedemption[]
  authoredThreads   Thread[]           @relation("ThreadAuthor")
  devices           DeviceToken[]
  reviews           Review[]
  wishlistItems     WishlistItem[]
  createdOrders     Order[]            @relation("OrderCreatedBy")
  wholesaleAccount  WholesaleAccount?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([storeId])
  @@index([kitchenId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256 of opaque refresh token
  deviceId  String?
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Single-use password-reset tokens (forgot-password flow). We store only the
// sha256 hash of the opaque token; the raw token travels by email link.
model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256 of opaque reset token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model EmailChange {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  tokenHash String    @unique // sha256 of opaque verification token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Org units
// ─────────────────────────────────────────────────────────────────────────────

model Store {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  address          String
  lat              Float?
  lng              Float?
  phone            String
  // JSON of weekly opening hours { mon: [["09:00","21:00"]], ... }
  openingHours     Json
  defaultKitchenId String?
  defaultKitchen   Kitchen? @relation(fields: [defaultKitchenId], references: [id])

  /// Minutes before a scheduled order's pickup/delivery time the merchant
  /// wants to start preparation. Used by the scheduler to surface orders
  /// in the merchant's "Due soon" view.
  preparationLeadMinutes Int @default(120)

  /// HCMC ward this branch physically sits in (slug from `hcm-wards.ts`).
  /// Drives the new same-ward / other-ward delivery fee rule.
  wardCode String?

  /// Master "stop everything" toggle. When true the store rejects every new
  /// order regardless of channel, with `pauseReason` shown to the customer.
  /// The two channel-specific flags below let the merchant pause just one
  /// fulfilment type (e.g. shipper not available → pause delivery only).
  isPaused         Boolean @default(false)
  isPickupPaused   Boolean @default(false)
  isDeliveryPaused Boolean @default(false)
  pauseReason      String?

  /// Minimum subtotal accepted on a new order (₫). 0 = no minimum.
  minOrderVnd      Int @default(0)
  /// Default advance notice (in hours) required for any order at this store.
  /// Product.leadTimeHours overrides this when set.
  defaultLeadHours Int @default(0)

  users              User[]
  products           Product[]
  orders             Order[]
  collections        Collection[]
  bundles            Bundle[]
  threads            Thread[]
  coupons            Coupon[]
  banners            Banner[]
  blackoutDates      StoreBlackoutDate[]
  requestedTransfers Order[]             @relation("OrderRequestingStore")
  incomingTransfers  Order[]             @relation("OrderDestinationStore")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton row driving the customer-site promotional popup. Bumping
/// `version` re-triggers display for all customers (clients persist the
/// last seen version in localStorage).
model PromoPopup {
  id               String   @id @default("default")
  isActive         Boolean  @default(false)
  title            String   @default("Chào mừng đến với Banan")
  body             String   @default("")
  imageUrl         String?
  ctaLabel         String?
  ctaUrl           String?
  /// 0 = no auto-close. Else closes after N seconds with a countdown bar.
  countdownSeconds Int      @default(0)
  version          Int      @default(1)
  updatedAt        DateTime @updatedAt
}

/// Singleton row holding the admin-tunable delivery-fee config. Pricing
/// has two tiers (standard products vs. items in the birthday cake
/// collection) × two distance bands (within `thresholdKm` vs. beyond).
/// Looked up by the fixed primary key "default" so we never need a
/// separate lookup table.
model DeliveryConfig {
  id                          String   @id @default("default")
  /// Standard products — same ward as the routed store (often free).
  standardFeeSameWardVnd      Int      @default(0)
  /// Standard products — customer ward differs from the routed store.
  standardFeeOtherWardVnd     Int      @default(30000)
  /// Birthday cakes — same ward as the routed store. Higher than standard
  /// because cakes are fragile + need careful handling.
  birthdayCakeFeeSameWardVnd  Int      @default(30000)
  /// Birthday cakes — different ward from the routed store.
  birthdayCakeFeeOtherWardVnd Int      @default(70000)
  /// Slug of the collection whose products get the "birthday cake" pricing
  /// tier. Matching is by Collection.slug so the admin can re-point this
  /// to a different curated set without code changes.
  birthdayCakeCollectionSlug  String   @default("home-birthday-cakes")
  /// Legacy field kept for backward compat — pre-2026 versions used a
  /// distance band rule. Ignored by the current ward-equality logic.
  thresholdKm                 Float    @default(3)
  updatedAt                   DateTime @updatedAt
}

/// One-off closure date for a store (Tết, public holidays, vacation). Orders
/// scheduled for the date are blocked with `reason` surfaced to the customer.
model StoreBlackoutDate {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  @@unique([storeId, date])
  @@index([storeId])
}

/// Home-page hero banner. Null storeId = chain-wide (admin). Merchants
/// manage their own store's banners.
model Banner {
  id        String  @id @default(uuid())
  storeId   String?
  store     Store?  @relation(fields: [storeId], references: [id])
  imageUrl  String
  title     String?
  ctaUrl    String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isActive])
}

model Kitchen {
  id              String @id @default(uuid())
  name            String
  address         String
  // Soft cap — used by capacity planner.
  capacityPerHour Int    @default(40)

  users             User[]
  storesAsDefault   Store[]
  productionBatches ProductionBatch[]
  orders            Order[]           @relation("KitchenOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id                     String    @id @default(uuid())
  name                   String
  slug                   String    @unique
  imageUrl               String?
  sortOrder              Int       @default(0)
  /// When true, the category is featured as a product strip on the customer
  /// home page (replacing the old Collection strips). All categories always
  /// appear as menu filter chips regardless of this flag.
  isPinnedToHome         Boolean   @default(false)
  /// At most ONE category is the "birthday cake" category. Products in it get
  /// isBirthdayCake=true (drives the cake-personalization wizard + the
  /// birthday delivery-fee tier). Replaces the old Collection-slug mechanism.
  isBirthdayCakeCategory Boolean   @default(false)
  /// Hidden categories vanish from the customer storefront entirely — no menu
  /// chip, no home strip, and their products are excluded from every customer
  /// product query (list, search, detail, recommendations). Merchant/admin
  /// still see them (to unhide). Products are untouched; unhiding restores them.
  isHidden               Boolean   @default(false)
  products               Product[]
}

model Product {
  id                 String    @id @default(uuid())
  storeId            String
  store              Store     @relation(fields: [storeId], references: [id])
  categoryId         String
  category           Category  @relation(fields: [categoryId], references: [id])
  name               String
  slug               String
  description        String    @db.Text
  basePrice          Decimal   @db.Decimal(12, 2)
  // Cover image is images[0]; gallery is images[1..].
  images             String[]
  // Free-form merchant-set badges shown on the customer card.
  // Examples: "Vegan", "Gluten-free", "Bestseller", "New".
  tags               String[]  @default([])
  preparationMinutes Int       @default(60)
  isAvailable        Boolean   @default(true)
  isSeasonal         Boolean   @default(false)
  seasonStart        DateTime?
  seasonEnd          DateTime?

  /// Per-product overrides for store-wide order rules.
  ///   leadTimeHours       — null = use Store.defaultLeadHours; else this.
  ///   availableDaysOfWeek — empty = every day. Else JS getDay() ints
  ///                          (0=Sun..6=Sat); only those days accept orders.
  ///   dailyMaxQuantity    — null = unlimited. Else a daily order cap
  ///                          enforced across all customers for that date.
  leadTimeHours       Int?
  availableDaysOfWeek Int[] @default([])
  dailyMaxQuantity    Int?

  /// Flavor-composition products (macaron sets). When [flavorPickCount]
  /// is set, the customer must compose exactly that many picks from
  /// [flavorOptions] before adding to cart — repeats allowed
  /// ("3× Jasmine + 2× Lemon" for a set of 5). Null = no composer.
  /// The chosen composition is stored on `OrderItem.personalization`
  /// as `{ "flavors": { "Jasmine": 3, "Lemon": 2 } }`.
  flavorPickCount Int?
  flavorOptions   String[] @default([])

  variants          ProductVariant[]
  orderItems        OrderItem[]
  collectionItems   CollectionItem[]
  linkedThreads     Thread[]                @relation("ThreadProduct")
  reviews           Review[]
  wishlistedBy      WishlistItem[]
  wholesaleLines    WholesaleContractLine[]
  bundleItems       BundleItem[]
  productionBatches ProductionBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([categoryId, isAvailable])
}

enum StockMode {
  UNLIMITED
  LIMITED
}

model ProductVariant {
  id                String                  @id @default(uuid())
  productId         String
  product           Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Size + flavor are required, even if "Default" — keeps the order item shape uniform.
  size              String
  flavor            String
  priceDelta        Decimal                 @default(0) @db.Decimal(12, 2)
  stockMode         StockMode               @default(UNLIMITED)
  stockQty          Int?
  isAvailable       Boolean                 @default(true)
  orderItems        OrderItem[]
  bundleItems       BundleItem[]
  productionBatches ProductionBatch[]
  wholesaleLines    WholesaleContractLine[]

  @@unique([productId, size, flavor])
}

// ─────────────────────────────────────────────────────────────────────────────
// Merchant-curated content: collections (group menus) + threads (homepage news)
// ─────────────────────────────────────────────────────────────────────────────

model Collection {
  id             String           @id @default(uuid())
  storeId        String
  store          Store            @relation(fields: [storeId], references: [id])
  name           String
  slug           String
  description    String?
  imageUrl       String?
  // Pinned collections are surfaced on the customer home page.
  isPinnedToHome Boolean          @default(false)
  sortOrder      Int              @default(0)
  isActive       Boolean          @default(true)
  items          CollectionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, isPinnedToHome])
}

model CollectionItem {
  id           String     @id @default(uuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)

  createdAt DateTime @default(now())

  @@unique([collectionId, productId])
}

/// Homepage feed entries — announcements, seasonal highlights, news.
/// `publishedAt = null` means draft.
model Thread {
  id                 String    @id @default(uuid())
  storeId            String
  store              Store     @relation(fields: [storeId], references: [id])
  authorId           String
  author             User      @relation("ThreadAuthor", fields: [authorId], references: [id])
  title              String
  body               String    @db.Text
  imageUrl           String?
  /// Carousel images (first is the cover). `imageUrl` kept for back-compat.
  images             String[]  @default([])
  /// Extracted from the body (#hashtag) on save; powers search + filter.
  hashtags           String[]  @default([])
  /// Optional "Shop this" deep-link target.
  productId          String?
  product            Product?  @relation("ThreadProduct", fields: [productId], references: [id])
  /// Configurable call-to-action button.
  ctaLabel           String?
  ctaUrl             String?
  /// When set + still in the future, the scheduler auto-publishes at this
  /// time (sets publishedAt). Lets merchants queue posts.
  scheduledPublishAt DateTime?
  /// Lightweight impression counter for the merchant insights view.
  viewCount          Int       @default(0)
  publishedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, publishedAt])
  @@index([scheduledPublishAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Customer assets
// ─────────────────────────────────────────────────────────────────────────────

model Address {
  id         String  @id @default(uuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String // "Home", "Office"
  recipient  String
  phone      String
  line1      String
  line2      String?
  city       String
  /// Legacy column — kept nullable for pre-reform addresses. New addresses
  /// rely on `wardCode` instead (HCMC's 2025 reform abolished districts).
  district   String?
  /// References our hard-coded HCMC ward catalog. Centroid (lat/lng) is
  /// resolved server-side so we can compute a haversine distance from the
  /// fulfilling store and surcharge delivery beyond a configurable radius.
  wardCode   String?
  postalCode String?
  lat        Float?
  lng        Float?
  isDefault  Boolean @default(false)
  orders     Order[]

  @@index([userId])
  @@index([wardCode])
}

enum PaymentProvider {
  STRIPE
  VNPAY // deprecated — replaced by PAYOS; value kept so existing rows/type stay valid
  MOMO
  CASH
  PAYOS // deprecated — replaced by NINEPAY; value kept so existing rows/type stay valid
  NINEPAY // 9Pay (9pay.vn) gateway — the active online provider
}

model PaymentMethod {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  PaymentProvider
  // Stripe pm_..., VNPay token, MoMo userId. Never raw card data.
  token     String
  brand     String?
  last4     String?
  expMonth  Int?
  expYear   Int?
  isDefault Boolean         @default(false)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────────────────────────────────────

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PREPARATION
  SENT_TO_KITCHEN
  READY_FOR_PICKUP
  DELIVERING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum KitchenStatus {
  PENDING_ACK // newly sent to kitchen, awaiting staff acknowledgement
  PREPARING // kitchen is actively making the order
  READY_DISPATCH // done — awaiting return to the merchant
}

/// Where an order came from. WEB is the public checkout; the rest are
/// operational channels that reuse the same pipeline with their own policy.
enum OrderSource {
  WEB
  STAFF_COUNTER // staff keyed it in at the shop counter
  WHOLESALE // contract customer, on-account settlement
  INTERNAL_TRANSFER // a branch ordering from the kitchen for itself
}

/// How the money side settles. ONLINE = gateway (WEB default); COUNTER_* =
/// cash till at the shop; ON_ACCOUNT = wholesale receivable;
/// INTERNAL_LEDGER = internal transfer, never retail revenue.
enum SettlementMode {
  ONLINE
  COUNTER_PAID
  COUNTER_UNPAID
  ON_ACCOUNT
  INTERNAL_LEDGER
}

model Order {
  id                String          @id @default(uuid())
  // Human-readable code like BAN-2026-000123. Generated by service.
  code              String          @unique
  customerId        String
  customer          User            @relation("CustomerOrders", fields: [customerId], references: [id])
  storeId           String
  store             Store           @relation(fields: [storeId], references: [id])
  kitchenId         String?
  kitchen           Kitchen?        @relation("KitchenOrders", fields: [kitchenId], references: [id])
  fulfillmentType   FulfillmentType
  scheduledFor      DateTime?
  /// Set the first time the scheduler surfaces this order as "due soon",
  /// so the cron doesn't spam the same order on every tick.
  dueSoonNotifiedAt DateTime?
  addressId         String?
  address           Address?        @relation(fields: [addressId], references: [id])
  status            OrderStatus     @default(PENDING)
  kitchenStatus     KitchenStatus?

  // ── channel + settlement (operational flows reuse this same pipeline) ──
  source              OrderSource          @default(WEB)
  settlementMode      SettlementMode       @default(ONLINE)
  // Staff/admin who keyed the order in (counter / internal transfer). Null
  // for self-service WEB/WHOLESALE orders.
  createdById         String?
  createdBy           User?                @relation("OrderCreatedBy", fields: [createdById], references: [id])
  /// Client-generated dedup key for staff-entered orders: a retried POST with
  /// the same (creator, key) returns the FIRST order instead of a duplicate.
  clientRequestId     String?
  // WHOLESALE only — the account + contract the prices were snapshot from.
  wholesaleAccountId  String?
  wholesaleAccount    WholesaleAccount?    @relation(fields: [wholesaleAccountId], references: [id])
  wholesaleContractId String?
  wholesaleContract   WholesaleContract?   @relation(fields: [wholesaleContractId], references: [id])
  // INTERNAL_TRANSFER only — which branch asked, which branch receives.
  requestingStoreId   String?
  requestingStore     Store?               @relation("OrderRequestingStore", fields: [requestingStoreId], references: [id])
  destinationStoreId  String?
  destinationStore    Store?               @relation("OrderDestinationStore", fields: [destinationStoreId], references: [id])
  receivable          WholesaleReceivable?

  // Money — all in minor units of order currency (default VND has none, so plain integer-ish decimals).
  currency          String         @default("VND")
  subtotal          Decimal        @db.Decimal(12, 2)
  deliveryFee       Decimal        @default(0) @db.Decimal(12, 2)
  pointsRedeemed    Int            @default(0)
  pointsDiscount    Decimal        @default(0) @db.Decimal(12, 2)
  couponId          String?
  coupon            Coupon?        @relation(fields: [couponId], references: [id])
  loyaltyEvents     LoyaltyEvent[]
  couponDiscount    Decimal        @default(0) @db.Decimal(12, 2)
  // Automatic promotion-engine discounts (product/category/flash/happy-hour…).
  campaignDiscount  Decimal        @default(0) @db.Decimal(12, 2)
  // [{ id, name, type, discountVnd }] of campaigns applied to this order.
  campaignInfo      Json?
  // Combo savings: when a cart line is a Bundle, it's expanded into its
  // constituent products at REGULAR prices (so each OrderItem keeps its true
  // menu price for VAT/reports), and the difference vs the bundle's flat
  // priceVnd is recorded here as a single "Giảm combo" discount line.
  bundleDiscount    Decimal        @default(0) @db.Decimal(12, 2)
  // Gift-card redemption applied to this order (balance-based; one card may
  // span several orders). `giftCardCode` is the code used; the amount is the
  // VND deducted from this order's total.
  giftCardCode      String?
  giftCardAmountVnd Int            @default(0)
  total             Decimal        @db.Decimal(12, 2)

  customMessage String?
  notes         String?

  // Gift order ("tặng quà khi đặt hàng") — the buyer sends this order as a
  // gift: a greeting-card message, an optional separate recipient, gift
  // wrapping, and the option to hide prices on the slip the recipient sees.
  isGift             Boolean @default(false)
  giftMessage        String?
  giftRecipientName  String?
  giftRecipientPhone String?
  giftWrap           Boolean @default(false)
  hidePrice          Boolean @default(false)

  // VAT invoice (hóa đơn đỏ) — optional company invoice request.
  // Toggled at checkout; the merchant fulfills outside the app (xuất hóa
  // đơn từ hệ thống thuế). We just persist the request data so the
  // merchant can issue the invoice and the customer can see status.
  requestVatInvoice  Boolean   @default(false)
  invoiceCompanyName String?
  invoiceTaxId       String?
  invoiceAddress     String?
  invoiceEmail       String?
  invoiceIssuedAt    DateTime?
  invoiceFileUrl     String?

  items             OrderItem[]
  reviews           Review[]
  payments          Payment[]
  refunds           Refund[]
  statusEvents      OrderStatusEvent[]
  couponRedemptions CouponRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([createdById, clientRequestId])
  @@index([customerId, createdAt])
  @@index([storeId, status])
  @@index([kitchenId, kitchenStatus])
  @@index([scheduledFor])
  @@index([source, createdAt])
}

// ── Wholesale (B2B on-account) ────────────────────────────────────────────
// Admin-managed. A wholesale customer is a regular CUSTOMER user whose
// WholesaleAccount is active; they order only what their contract lists, at
// contract prices, settled on account (receivables below).

model WholesaleAccount {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  companyName     String
  contactName     String?
  contactPhone    String?
  taxId           String?
  billingEmail    String?
  deliveryAddress String?
  active          Boolean @default(true)
  /// Max total OPEN/PARTIAL receivables (₫). 0 = no credit — every new order
  /// is refused until debts are paid.
  creditLimitVnd  Int     @default(0)
  /// Days from order confirmation to receivable due date.
  paymentTermDays Int     @default(30)
  blockedReason   String?

  contracts   WholesaleContract[]
  orders      Order[]
  receivables WholesaleReceivable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WholesaleContract {
  id                 String           @id @default(uuid())
  wholesaleAccountId String
  account            WholesaleAccount @relation(fields: [wholesaleAccountId], references: [id])
  name               String
  startsAt           DateTime
  endsAt             DateTime?
  active             Boolean          @default(true)
  minOrderVnd        Int?
  /// Fallback % off the retail price for lines without a fixedPriceVnd.
  defaultDiscountPct Decimal?         @db.Decimal(5, 2)
  /// Overrides the account's paymentTermDays when set.
  paymentTermDays    Int?

  lines  WholesaleContractLine[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wholesaleAccountId, active])
}

model WholesaleContractLine {
  id            String            @id @default(uuid())
  contractId    String
  contract      WholesaleContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant?   @relation(fields: [variantId], references: [id])
  /// Contract price per unit (₫). When null, price = retail − discountPct
  /// (line's, else contract default).
  fixedPriceVnd Int?
  discountPct   Decimal?          @db.Decimal(5, 2)
  minQty        Int               @default(1)
  active        Boolean           @default(true)
  leadTimeHours Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId, active])
}

enum WholesaleReceivableStatus {
  PENDING
  OPEN
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model WholesaleReceivable {
  id                 String                    @id @default(uuid())
  wholesaleAccountId String
  account            WholesaleAccount          @relation(fields: [wholesaleAccountId], references: [id])
  orderId            String                    @unique
  order              Order                     @relation(fields: [orderId], references: [id])
  amountVnd          Decimal                   @db.Decimal(12, 2)
  dueDate            DateTime?
  status             WholesaleReceivableStatus @default(PENDING)
  paidAt             DateTime?
  confirmedByAdminId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wholesaleAccountId, status])
}

model OrderItem {
  id            String          @id @default(uuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product         @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  // Snapshot at purchase time; do NOT recompute from product later.
  productName   String
  variantLabel  String?
  quantity      Int
  unitPrice     Decimal         @db.Decimal(12, 2)
  customMessage String?
  lineTotal     Decimal         @db.Decimal(12, 2)

  /// Cake personalization payload — only set when the customer used the
  /// wizard (shown for products in the `birthdayCakeCollectionSlug`
  /// from `DeliveryConfig`). Schema-less so we can evolve the wizard
  /// without DB migrations:
  ///   {
  ///     "textOnCake": "Happy birthday Mai",
  ///     "candleCount": 7,
  ///     "referenceImageUrl": "https://...",
  ///     "note": "Ribbon vàng, không sprinkles"
  ///   }
  personalization Json?
}

model OrderStatusEvent {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  actorId    String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([orderId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payments & refunds
// ─────────────────────────────────────────────────────────────────────────────

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  FAILED
  VOIDED
  REFUNDED
}

model Payment {
  id          String          @id @default(uuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id])
  provider    PaymentProvider
  // Stripe payment_intent.id, VNPay vnp_TxnRef, MoMo requestId.
  providerRef String
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("VND")
  status      PaymentStatus
  // Verbatim webhook payload for audit & retry decisions.
  rawPayload  Json?
  refunds     Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerRef])
  @@index([orderId])
}

enum RefundStatus {
  REQUESTED
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

model Refund {
  id            String       @id @default(uuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id])
  paymentId     String?
  payment       Payment?     @relation(fields: [paymentId], references: [id])
  amount        Decimal      @db.Decimal(12, 2)
  reason        String
  status        RefundStatus @default(REQUESTED)
  requestedById String
  approvedById  String?
  // Filled after provider confirmation.
  providerRef   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Loyalty
// ─────────────────────────────────────────────────────────────────────────────

enum LoyaltyEventType {
  EARN
  REDEEM
  EXPIRE
  BIRTHDAY
  ADJUSTMENT
}

model LoyaltyEvent {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  orderId      String?
  // Points are money-adjacent (they convert to a discount), so the ledger's
  // order reference is a real FK. SetNull keeps the historical event if an
  // order is ever removed rather than silently dangling.
  order        Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type         LoyaltyEventType
  delta        Int
  balanceAfter Int
  reason       String?
  expiresAt    DateTime?
  createdAt    DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
}

enum CouponType {
  PERCENT
  FIXED
  FREE_DELIVERY
}

enum CampaignType {
  PRODUCT_DISCOUNT
  CATEGORY_DISCOUNT
  FLASH_SALE
  HAPPY_HOUR
  BUY_X_GET_Y
  FIRST_ORDER
  BIRTHDAY
  REACTIVATION
  MEMBERSHIP_BENEFIT
}

/// Unified promotion campaign. Type-specific settings live in `config` (JSON);
/// the promotion engine evaluates active campaigns at checkout. Voucher,
/// free-shipping and fixed discounts stay on Coupon; combos stay on Bundle —
/// this model powers the automatic + targeted campaign types.
model Campaign {
  id           String               @id @default(uuid())
  type         CampaignType
  name         String
  isActive     Boolean              @default(true)
  priority     Int                  @default(0)
  stackable    Boolean              @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  config       Json
  storeId      String? // null = chain-wide
  usageLimit   Int?
  usedCount    Int                  @default(0)
  perUserLimit Int?
  redemptions  CampaignRedemption[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([type])
  @@index([isActive])
}

/// Per-order record that a campaign was applied. Backs per-user campaign
/// limit enforcement (mirrors CouponRedemption) — without it `perUserLimit`
/// and `usedCount` were unenforceable. userId/orderId are plain columns (no
/// FK) to keep the ledger append-only and decoupled from order/user deletion.
model CampaignRedemption {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String
  orderId    String
  createdAt  DateTime @default(now())

  @@unique([campaignId, userId, orderId])
  @@index([campaignId, userId])
}

model Coupon {
  id             String     @id @default(uuid())
  code           String     @unique
  type           CouponType
  value          Decimal    @db.Decimal(12, 2)
  minSubtotal    Decimal?   @db.Decimal(12, 2)
  startsAt       DateTime
  endsAt         DateTime
  maxRedemptions Int?
  redemptions    Int        @default(0)
  perUserLimit   Int        @default(1)
  isActive       Boolean    @default(true)

  /// Owning store. Null = chain-wide (admin-issued, valid at any store).
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])
  /// Merchant-facing description shown in the coupon manager.
  label   String?

  redemptionLog CouponRedemption[]
  orders        Order[]

  createdAt DateTime @default(now())

  @@index([storeId])
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  createdAt DateTime @default(now())

  @@unique([couponId, userId, orderId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Kitchen production
// ─────────────────────────────────────────────────────────────────────────────

enum BatchStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionBatch {
  id           String          @id @default(uuid())
  kitchenId    String
  kitchen      Kitchen         @relation(fields: [kitchenId], references: [id])
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  plannedQty   Int
  actualQty    Int             @default(0)
  scheduledFor DateTime
  status       BatchStatus     @default(PLANNED)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kitchenId, scheduledFor])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

/// One push-notification target per device. The customer / staff app
/// registers its FCM token here on launch; we wipe it on logout.
/// `platform` lets us target a specific app surface (web push, iOS, APK).
enum DevicePlatform {
  WEB
  IOS
  ANDROID
}

model DeviceToken {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  DevicePlatform
  token     String         @unique
  lastSeen  DateTime       @default(now())
  createdAt DateTime       @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Reviews & wishlist (P0 conversion features)
// ─────────────────────────────────────────────────────────────────────────────

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

/// Customer review of a product. Only customers who have a completed
/// order containing the product can review (enforced by the service).
/// Each user can leave at most one review per product (composite unique).
model Review {
  id             String       @id @default(uuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId        String?
  order          Order?       @relation(fields: [orderId], references: [id])
  rating         Int // 1..5
  body           String?      @db.Text
  images         String[]     @default([])
  status         ReviewStatus @default(PUBLISHED)
  /// Merchant moderation note (visible to admin/merchant only).
  moderationNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId, status, createdAt])
  @@index([userId, createdAt])
}

/// A fixed-price combo of products — "Combo bữa sáng = 1 croissant + 1
/// cà phê" etc. The bundle has its own price and image; the items it
/// includes link to existing Product rows so we don't duplicate catalog
/// data. At order time the bundle becomes a single OrderItem with
/// `productName` = bundle name and the constituent items snapshotted in
/// the `personalization`-style metadata (kept simple — the kitchen
/// reads it for what to make).
model Bundle {
  id             String       @id @default(uuid())
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id])
  name           String
  slug           String
  description    String?      @db.Text
  imageUrl       String?
  priceVnd       Int
  isActive       Boolean      @default(true)
  isPinnedToHome Boolean      @default(false)
  sortOrder      Int          @default(0)
  items          BundleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, isPinnedToHome])
}

model BundleItem {
  id        String          @id @default(uuid())
  bundleId  String
  bundle    Bundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  /// Optional variant pin — null = use the product's default variant at
  /// order time. Useful when a bundle specifies "the matcha flavour" of
  /// a multi-flavour product.
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int             @default(1)

  @@unique([bundleId, productId, variantId])
}

/// Singleton (id = "default") of chain-wide customer-facing display
/// preferences. Right now it carries one toggle — whether to show
/// stock-remaining badges on the customer site — but it's designed to
/// grow as we add other "should the storefront show X?" controls
/// (review counts, recently viewed, etc.).
///
/// Merchant-editable static page content (FAQ, About …). One row per
/// page, keyed by a stable string. `data` is free-form JSON whose shape
/// depends on the key (FAQ = { items:[{q,a}] }, About = { intro, sections:
/// [{heading,body}] }). The service falls back to a built-in default when a
/// row is absent, so the customer always sees content.
model SiteContent {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

/// Admin-controlled marketing programs. Singleton (id="default"). Each
/// program ships DISABLED — admin flips it on and tweaks its config from
/// the merchant "Chương trình Marketing" page. `*Config` JSON holds the
/// per-program settings (shapes documented in the marketing module's
/// defaults). Customer surfaces are hidden until the matching flag is true.
model MarketingConfig {
  id String @id @default("default")

  referralEnabled     Boolean @default(false)
  referralConfig      Json?
  giftCardEnabled     Boolean @default(false)
  giftCardConfig      Json?
  subscriptionEnabled Boolean @default(false)
  subscriptionConfig  Json?
  cateringEnabled     Boolean @default(false)
  cateringConfig      Json?
  rewardsEnabled      Boolean @default(false)
  rewardsConfig       Json?

  updatedAt DateTime @updatedAt
}

/// Prepaid gift card / e-voucher. Admin issues one → a unique `code` is
/// generated with a starting value; `balanceVnd` decrements as the customer
/// redeems it across one or more orders at checkout.
model GiftCard {
  id         String    @id @default(uuid())
  code       String    @unique
  initialVnd Int
  balanceVnd Int
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  note       String?
  issuedById String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([isActive])
}

/// Stock is intentionally OFF by default: the underlying `stockQty`
/// lives on `ProductVariant` and is shared across every branch, so
/// surfacing "Còn 3 cái" can mislead a customer in a different branch.
/// Merchants flip the toggle on only when stock is genuinely scarce
/// chain-wide (limited-edition releases, seasonal drops).
model DisplayConfig {
  id                   String  @id @default("default")
  showStockToCustomers Boolean @default(false)

  /// Contact widget — a floating "Liên hệ" FAB on the customer site
  /// that surfaces these channels in a bottom sheet. Each field null →
  /// that channel is hidden from the sheet. When every field is null
  /// the FAB itself is hidden.
  contactPhone       String?
  contactZaloOaId    String? // Zalo Official Account id → deep link `https://zalo.me/{id}`
  contactMessengerId String? // FB page username → `https://m.me/{id}`
  contactEmail       String?

  updatedAt DateTime @updatedAt
}

/// Heart / "Yêu thích" — saved products per customer.
model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

/// Marketing mailing list. Double opt-in flow:
///   1. Customer submits email → row created with `confirmedAt = null`.
///   2. Resend sends a verify email with `unsubscribeToken` link.
///   3. Customer clicks link → `confirmedAt = now()`.
///   4. Unsubscribe at any time via the same token in the email footer.
///
/// Phone-only is optional (we accept email-only for now). The
/// `source` field tracks where the signup came from (footer / popup /
/// checkout / merchant-bulk) so we can measure each channel.
model NewsletterSubscriber {
  id               String    @id @default(uuid())
  email            String    @unique
  fullName         String?
  source           String?
  unsubscribeToken String    @unique @default(uuid())
  subscribedAt     DateTime  @default(now())
  confirmedAt      DateTime?
  unsubscribedAt   DateTime?

  @@index([confirmedAt])
  @@index([subscribedAt])
}

/// A sent newsletter email campaign — kept as history so the merchant can
/// review what was sent, to whom, and how many landed.
model NewsletterCampaign {
  id         String   @id @default(uuid())
  subject    String
  body       String   @db.Text
  imageUrl   String?
  audience   String // 'subscribers' | 'customers' | 'both'
  alsoInApp  Boolean  @default(false)
  recipients Int      @default(0)
  emailsSent Int      @default(0)
  inAppSent  Int      @default(0)
  sentById   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Manufacturing (Kitchen MES) — the "Sản xuất" section of the kitchen app.
// Fully namespaced under `Mfg*` so it never collides with the ordering side
// (Product, ProductionBatch, kitchen queue). Increment 1 = the P0 spine:
// 3-tier products, UoM, multi-level BoM + ratio%, MO produce→lot→stock→consume,
// AVCO costing, scrap, traceability. QC / shop-floor / schedule / MPS land in
// later increments. See docs/kitchen-mes.md.
// ─────────────────────────────────────────────────────────────────────────────

enum MfgProductType {
  RAW // nguyên liệu
  SEMI // bán thành phẩm
  FINISHED // thành phẩm
  PACKAGING // bao bì
}

enum MfgCostMethod {
  AVCO // bình quân gia quyền — raw materials
  STANDARD // giá chuẩn — finished goods
}

enum MfgTracking {
  NONE
  LOT
}

enum MfgLocationType {
  INTERNAL
  SUPPLIER
  PRODUCTION
  SCRAP
}

enum MfgMoState {
  DRAFT
  CONFIRMED
  PROGRESS
  DONE
  CANCEL
}

enum MfgAvailability {
  AVAILABLE
  NOT_AVAILABLE
}

enum MfgWoState {
  PENDING
  READY
  PROGRESS
  BLOCKED
  DONE
  CANCEL
}

enum MfgMoveRef {
  RECEIPT
  DELIVERY
  INTERNAL
  MO // produce (finished in / component out)
  SCRAP
}

model MfgUom {
  id       String  @id @default(uuid())
  code     String  @unique
  nameVi   String
  nameEn   String
  // UoMs convert only within the same category (weight to weight).
  category String // 'weight' | 'unit' | 'volume'
  // Multiplier to the category's reference unit (gram for weight). kg to 1000.
  factor   Decimal @db.Decimal(14, 6)
  rounding Decimal @default(0.001) @db.Decimal(14, 6)

  products     MfgProduct[]
  bomLines     MfgBomLine[]
  boms         MfgBom[]
  moComponents MfgOrderComponent[]
  orders       MfgOrder[]
  scraps       MfgScrap[]
  moves        MfgStockMove[]

  createdAt DateTime @default(now())
}

model MfgCategory {
  id         String        @id @default(uuid())
  nameVi     String
  nameEn     String
  costMethod MfgCostMethod @default(AVCO)

  products MfgProduct[]

  createdAt DateTime @default(now())
}

model MfgProduct {
  id             String         @id @default(uuid())
  code           String         @unique
  nameVi         String
  nameEn         String
  categoryId     String
  category       MfgCategory    @relation(fields: [categoryId], references: [id])
  uomId          String
  uom            MfgUom         @relation(fields: [uomId], references: [id])
  type           MfgProductType
  tracking       MfgTracking    @default(NONE)
  useExpiration  Boolean        @default(false)
  expirationDays Int            @default(0)
  // Standard cost (finished/manual). AVCO cost is maintained on avgCost as
  // receipts/produces roll in.
  standardCost   Decimal        @default(0) @db.Decimal(14, 2)
  avgCost        Decimal        @default(0) @db.Decimal(14, 2)
  active         Boolean        @default(true)

  boms            MfgBom[]            @relation("ProductBoms")
  bomLines        MfgBomLine[]
  bomByproducts   MfgBomByproduct[]
  orders          MfgOrder[]
  orderComponents MfgOrderComponent[]
  lots            MfgLot[]
  quants          MfgStockQuant[]
  moves           MfgStockMove[]
  scraps          MfgScrap[]
  qualityPoints   MfgQualityPoint[]
  qualityAlerts   MfgQualityAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

model MfgWorkCenter {
  id          String  @id @default(uuid())
  code        String  @unique
  nameVi      String
  nameEn      String
  costPerHour Decimal @default(0) @db.Decimal(14, 2)
  capacity    Int     @default(1)
  active      Boolean @default(true)

  bomOperations MfgBomOperation[]
  workOrders    MfgWorkOrder[]
  maintenances  MfgMaintenance[]

  createdAt DateTime @default(now())
}

enum MfgMaintenanceType {
  PREVENTIVE // bảo trì định kỳ
  CORRECTIVE // sửa chữa hỏng hóc
}

enum MfgMaintenanceState {
  PLANNED
  DONE
}

/// A maintenance job on a work centre. Done jobs carry `downtimeMin`, which feeds
/// the OEE availability calculation for that centre.
model MfgMaintenance {
  id            String              @id @default(uuid())
  workCenterId  String
  workCenter    MfgWorkCenter       @relation(fields: [workCenterId], references: [id])
  type          MfgMaintenanceType  @default(PREVENTIVE)
  state         MfgMaintenanceState @default(PLANNED)
  scheduledDate DateTime
  doneDate      DateTime?
  downtimeMin   Int                 @default(0)
  note          String?
  createdAt     DateTime            @default(now())

  @@index([workCenterId, state])
  @@index([doneDate])
}

model MfgBom {
  id        String     @id @default(uuid())
  productId String
  product   MfgProduct @relation("ProductBoms", fields: [productId], references: [id])
  outputQty Decimal    @default(1) @db.Decimal(14, 3)
  uomId     String
  uom       MfgUom     @relation(fields: [uomId], references: [id])
  version   Int        @default(1)
  active    Boolean    @default(true)

  lines      MfgBomLine[]
  operations MfgBomOperation[]
  byproducts MfgBomByproduct[]
  orders     MfgOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, active])
}

model MfgBomLine {
  id           String     @id @default(uuid())
  bomId        String
  bom          MfgBom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentId  String
  component    MfgProduct @relation(fields: [componentId], references: [id])
  qty          Decimal    @db.Decimal(14, 3)
  uomId        String
  uom          MfgUom     @relation(fields: [uomId], references: [id])
  // Baker's percentage vs the BoM's flour (or total) weight. Derived; stored
  // so a saved recipe keeps the number the baker entered.
  ratioPercent Decimal    @default(0) @db.Decimal(9, 4)

  @@index([bomId])
}

model MfgBomOperation {
  id              String        @id @default(uuid())
  bomId           String
  bom             MfgBom        @relation(fields: [bomId], references: [id], onDelete: Cascade)
  sequence        Int
  nameVi          String
  nameEn          String
  workCenterId    String
  workCenter      MfgWorkCenter @relation(fields: [workCenterId], references: [id])
  durationMinutes Int           @default(0)

  workOrders    MfgWorkOrder[]
  qualityPoints MfgQualityPoint[]

  @@unique([bomId, sequence])
}

model MfgBomByproduct {
  id        String     @id @default(uuid())
  bomId     String
  bom       MfgBom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productId String
  product   MfgProduct @relation(fields: [productId], references: [id])
  qty       Decimal    @db.Decimal(14, 3)
}

model MfgLocation {
  id     String          @id @default(uuid())
  code   String          @unique
  nameVi String
  nameEn String
  type   MfgLocationType @default(INTERNAL)

  quants    MfgStockQuant[]
  movesFrom MfgStockMove[]  @relation("MoveSrc")
  movesTo   MfgStockMove[]  @relation("MoveDest")
  scraps    MfgScrap[]

  createdAt DateTime @default(now())
}

model MfgLot {
  id         String     @id @default(uuid())
  productId  String
  product    MfgProduct @relation(fields: [productId], references: [id])
  name       String
  mfgDate    DateTime   @default(now())
  expiryDate DateTime?

  quants MfgStockQuant[]
  moves  MfgStockMove[]
  orders MfgOrder[]
  scraps MfgScrap[]

  createdAt DateTime @default(now())

  @@unique([productId, name])
  @@index([expiryDate])
}

model MfgStockQuant {
  id          String      @id @default(uuid())
  productId   String
  product     MfgProduct  @relation(fields: [productId], references: [id])
  lotId       String?
  lot         MfgLot?     @relation(fields: [lotId], references: [id])
  locationId  String
  location    MfgLocation @relation(fields: [locationId], references: [id])
  // On-hand in the product's own UoM (grams for weight-tracked items).
  quantity    Decimal     @default(0) @db.Decimal(14, 3)
  reservedQty Decimal     @default(0) @db.Decimal(14, 3)

  reservations MfgReservation[]

  updatedAt DateTime @updatedAt

  @@unique([productId, lotId, locationId])
  @@index([productId, lotId, locationId])
}

/// A per-MO hard allocation: how much of a specific quant an MO has reserved. The
/// sum of a quant's reservations equals its `reservedQty`; releasing/consuming an
/// MO touches only its own rows, so cancel/produce can't free another MO's hold.
model MfgReservation {
  id        String        @id @default(uuid())
  moId      String
  mo        MfgOrder      @relation(fields: [moId], references: [id], onDelete: Cascade)
  quantId   String
  quant     MfgStockQuant @relation(fields: [quantId], references: [id], onDelete: Cascade)
  productId String
  qty       Decimal       @db.Decimal(14, 3)
  createdAt DateTime      @default(now())

  @@index([moId])
  @@index([quantId])
}

model MfgStockMove {
  id             String      @id @default(uuid())
  productId      String
  product        MfgProduct  @relation(fields: [productId], references: [id])
  lotId          String?
  lot            MfgLot?     @relation(fields: [lotId], references: [id])
  qty            Decimal     @db.Decimal(14, 3)
  uomId          String
  uom            MfgUom      @relation(fields: [uomId], references: [id])
  srcLocationId  String
  srcLocation    MfgLocation @relation("MoveSrc", fields: [srcLocationId], references: [id])
  destLocationId String
  destLocation   MfgLocation @relation("MoveDest", fields: [destLocationId], references: [id])
  refType        MfgMoveRef
  // Free ref id (MfgOrder.id for produce/consume, MfgScrap.id for scrap).
  refId          String?
  unitCost       Decimal     @default(0) @db.Decimal(14, 2)
  date           DateTime    @default(now())

  @@index([productId, date])
  @@index([refType, refId])
  @@index([lotId])
}

model MfgOrder {
  id            String     @id @default(uuid())
  code          String     @unique
  productId     String
  product       MfgProduct @relation(fields: [productId], references: [id])
  bomId         String
  bom           MfgBom     @relation(fields: [bomId], references: [id])
  qtyToProduce  Decimal    @db.Decimal(14, 3)
  qtyProduced   Decimal    @default(0) @db.Decimal(14, 3)
  uomId         String
  uom           MfgUom     @relation(fields: [uomId], references: [id])
  state         MfgMoState @default(DRAFT)
  scheduledDate DateTime?
  responsibleId String?
  lotId         String?
  lot           MfgLot?    @relation(fields: [lotId], references: [id])
  // Snapshotted total cost at produce time (materials + operations).
  totalCost     Decimal    @default(0) @db.Decimal(14, 2)

  components    MfgOrderComponent[]
  workOrders    MfgWorkOrder[]
  scraps        MfgScrap[]
  qualityChecks MfgQualityCheck[]
  qualityAlerts MfgQualityAlert[]
  reservations  MfgReservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
}

model MfgOrderComponent {
  id           String          @id @default(uuid())
  moId         String
  mo           MfgOrder        @relation(fields: [moId], references: [id], onDelete: Cascade)
  productId    String
  product      MfgProduct      @relation(fields: [productId], references: [id])
  qtyToConsume Decimal         @db.Decimal(14, 3)
  qtyConsumed  Decimal         @default(0) @db.Decimal(14, 3)
  uomId        String
  uom          MfgUom          @relation(fields: [uomId], references: [id])
  availability MfgAvailability @default(NOT_AVAILABLE)
  reservedQty  Decimal         @default(0) @db.Decimal(14, 3)

  @@index([moId])
}

model MfgWorkOrder {
  id               String          @id @default(uuid())
  moId             String
  mo               MfgOrder        @relation(fields: [moId], references: [id], onDelete: Cascade)
  bomOperationId   String
  bomOperation     MfgBomOperation @relation(fields: [bomOperationId], references: [id])
  workCenterId     String
  workCenter       MfgWorkCenter   @relation(fields: [workCenterId], references: [id])
  sequence         Int
  state            MfgWoState      @default(PENDING)
  durationExpected Int             @default(0)
  durationReal     Int             @default(0)
  dateStart        DateTime?
  dateFinished     DateTime?

  qualityChecks MfgQualityCheck[]

  @@unique([moId, sequence])
  @@index([moId])
}

model MfgScrap {
  id         String      @id @default(uuid())
  productId  String
  product    MfgProduct  @relation(fields: [productId], references: [id])
  lotId      String?
  lot        MfgLot?     @relation(fields: [lotId], references: [id])
  qty        Decimal     @db.Decimal(14, 3)
  uomId      String
  uom        MfgUom      @relation(fields: [uomId], references: [id])
  locationId String
  location   MfgLocation @relation(fields: [locationId], references: [id])
  reason     String
  moId       String?
  mo         MfgOrder?   @relation(fields: [moId], references: [id])
  date       DateTime    @default(now())

  @@index([productId, date])
}

// ── Kitchen MES increment 3: quality control (QC) ────────────────────────────

enum MfgTestType {
  MEASURE // đo giá trị (nhiệt độ...) — pass khi trong [normMin, normMax]
  PASS_FAIL // đạt / không đạt (nhũ hoá, không bọt/váng/vật lạ)
}

enum MfgCheckResult {
  NONE
  PASS
  FAIL
}

enum MfgAlertStage {
  NEW
  CONFIRMED
  SOLVED
}

/// A control point attached to a BoM operation (HACCP-style). MEASURE points
/// carry a norm range the measured value must land in to pass.
model MfgQualityPoint {
  id             String           @id @default(uuid())
  titleVi        String
  titleEn        String
  testType       MfgTestType
  bomOperationId String?
  bomOperation   MfgBomOperation? @relation(fields: [bomOperationId], references: [id])
  productId      String?
  product        MfgProduct?      @relation(fields: [productId], references: [id])
  normMin        Decimal?         @db.Decimal(10, 2)
  normMax        Decimal?         @db.Decimal(10, 2)
  unit           String? // °C, ...
  active         Boolean          @default(true)

  checks MfgQualityCheck[]

  createdAt DateTime @default(now())

  @@index([bomOperationId])
}

/// A recorded result against a control point during a work order.
model MfgQualityCheck {
  id             String          @id @default(uuid())
  qualityPointId String
  qualityPoint   MfgQualityPoint @relation(fields: [qualityPointId], references: [id])
  moId           String?
  mo             MfgOrder?       @relation(fields: [moId], references: [id])
  workOrderId    String?
  workOrder      MfgWorkOrder?   @relation(fields: [workOrderId], references: [id])
  result         MfgCheckResult  @default(NONE)
  measuredValue  Decimal?        @db.Decimal(10, 2)
  note           String?
  userId         String?
  date           DateTime        @default(now())

  @@index([workOrderId])
  @@index([moId])
}

/// Raised when a check fails (or by staff). Worked through NEW → CONFIRMED →
/// SOLVED.
model MfgQualityAlert {
  id          String        @id @default(uuid())
  title       String
  moId        String?
  mo          MfgOrder?     @relation(fields: [moId], references: [id])
  productId   String?
  product     MfgProduct?   @relation(fields: [productId], references: [id])
  stage       MfgAlertStage @default(NEW)
  description String?
  // When the scheduler pushed a notification for this alert (dedup — notify once).
  notifiedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([stage])
}
