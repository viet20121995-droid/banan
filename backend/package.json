    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "nestjs-pino": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
