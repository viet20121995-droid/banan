# Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://banan:banan@localhost:5432/banan?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS — comma-separated origins for the 3 Flutter web apps in dev
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# S3 / R2 (M2)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=banan-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Stripe (M4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 9Pay (online QR / card / bank — the active online provider). Keys from the
# 9Pay merchant dashboard (developers.9pay.vn). Register the IPN URL there:
#   <API_BASE>/api/v1/payments/ninepay/ipn
# NINEPAY_ENDPOINT defaults to SANDBOX — set to https://payment.9pay.vn for prod.
NINEPAY_MERCHANT_KEY=
NINEPAY_SECRET_KEY=
NINEPAY_CHECKSUM_KEY=
# Optional overrides (sensible defaults applied if blank):
# NINEPAY_ENDPOINT=https://sand-payment.9pay.vn
# NINEPAY_RETURN_URL=http://localhost:3000/api/v1/payments/ninepay/return

# MoMo (M4)
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# Email (Resend) — leave empty in dev to log payloads instead of sending.
# Sign up at https://resend.com (3,000 emails/month free).
RESEND_API_KEY=
EMAIL_FROM=Banan <onboarding@resend.dev>

# FCM (M8)
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm-service-account.json
