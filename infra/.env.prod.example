# ── Banan production env — copy to infra/.env.prod and fill in. NEVER commit
# the real .env.prod (it's gitignored). Generate secrets with:
#   openssl rand -base64 48    (JWT secrets, DB/Redis passwords)
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Base domain — Caddy serves api.<domain> (API) + <domain>/merchant/kitchen
# (the 3 web apps) and auto-issues SSL for all of them.
BASE_DOMAIN=banan.com

# ── Datastores (hostnames = docker service names; passwords below) ────────────
DB_PASSWORD=__CHANGE_ME_strong_random__
REDIS_PASSWORD=__CHANGE_ME_strong_random__
DATABASE_URL=postgresql://banan:__CHANGE_ME_strong_random__@postgres:5432/banan?schema=public
REDIS_URL=redis://:__CHANGE_ME_strong_random__@redis:6379
# ^ The password inside DATABASE_URL / REDIS_URL MUST equal DB_PASSWORD /
#   REDIS_PASSWORD above.

# ── Auth (REQUIRED — must be long random; never the dev placeholders) ─────────
JWT_ACCESS_SECRET=__CHANGE_ME_openssl_rand_base64_48__
JWT_REFRESH_SECRET=__CHANGE_ME_openssl_rand_base64_48__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── CORS — the 3 customer-facing web origins (comma-separated, NO trailing /) ─
CORS_ORIGINS=https://banan.com,https://www.banan.com,https://merchant.banan.com,https://kitchen.banan.com

# ── Customer app base (used for VNPay return + email links) ───────────────────
CUSTOMER_APP_BASE_URL=https://banan.com

# ── Email (Resend). Empty = dry-run (logs only). ─────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Banan <no-reply@banan.com>
# Optional support inbox for the contact form (defaults to EMAIL_FROM):
CONTACT_TO=support@banan.com

# ── FCM web push — place the service-account JSON at backend/secrets/ ─────────
FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# ── VNPay (use PRODUCTION merchant credentials when going live) ───────────────
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://pay.vnpay.vn/vpcpay.html
VNPAY_RETURN_URL=https://api.banan.com/api/v1/payments/vnpay/return
VNPAY_IPN_URL=https://api.banan.com/api/v1/payments/vnpay/ipn

# ── Optional: MoMo / Stripe — leave empty to keep disabled ────────────────────
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
