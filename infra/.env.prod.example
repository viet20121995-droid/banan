# ── Banan production env — copy to infra/.env.prod and fill in. NEVER commit
# the real .env.prod (it's gitignored). Generate secrets with:
#   openssl rand -base64 48    (JWT secrets, DB/Redis passwords)
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Base domain — Caddy serves api.<domain> (API) + <domain>/merchant/kitchen
# (the 3 web apps) and auto-issues SSL for all of them.
BASE_DOMAIN=banancakes.vn

# ── Datastores (hostnames = docker service names; passwords below) ────────────
DB_PASSWORD=__CHANGE_ME_strong_random__
REDIS_PASSWORD=__CHANGE_ME_strong_random__
DATABASE_URL=postgresql://banan:__CHANGE_ME_strong_random__@postgres:5432/banan?schema=public
REDIS_URL=redis://:__CHANGE_ME_strong_random__@redis:6379
# ^ The password inside DATABASE_URL / REDIS_URL MUST equal DB_PASSWORD /
#   REDIS_PASSWORD above.

# ── Auth (REQUIRED — must be long random; never the dev placeholders) ─────────
JWT_ACCESS_SECRET=__CHANGE_ME_openssl_rand_base64_48__
JWT_REFRESH_SECRET=__CHANGE_ME_openssl_rand_base64_48__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── CORS — the 3 customer-facing web origins (comma-separated, NO trailing /) ─
CORS_ORIGINS=https://banancakes.vn,https://www.banancakes.vn,https://merchant.banancakes.vn,https://kitchen.banancakes.vn

# ── Customer app base (used for VNPay return + email links) ───────────────────
CUSTOMER_APP_BASE_URL=https://banancakes.vn

# ── Email (Resend). Empty = dry-run (logs only). ─────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Banan <no-reply@banancakes.vn>
# Optional support inbox for the contact form (defaults to EMAIL_FROM):
CONTACT_TO=support@banancakes.vn

# ── FCM web push — place the service-account JSON at backend/secrets/ ─────────
FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# ── 9Pay (online QR / card / bank — the active online provider) ───────────────
# Keys from the 9Pay merchant dashboard. NINEPAY_ENDPOINT defaults to SANDBOX
# (https://sand-payment.9pay.vn) — TEST a real sandbox payment first, THEN set
# it to https://payment.9pay.vn for production. After filling these, register
# the IPN URL in the 9Pay dashboard:
#   https://api.banancakes.vn/api/v1/payments/ninepay/ipn
# and the return URL (NINEPAY_RETURN_URL below) as the allowed return domain.
NINEPAY_MERCHANT_KEY=
NINEPAY_SECRET_KEY=
NINEPAY_CHECKSUM_KEY=
NINEPAY_ENDPOINT=https://sand-payment.9pay.vn
NINEPAY_RETURN_URL=https://api.banancakes.vn/api/v1/payments/ninepay/return

# ── COD (tiền mặt khi nhận hàng) ──────────────────────────────────────────────
# Off unless set to the literal "true". The storefront is online-prepaid only,
# so the API refuses paymentMethod=CASH with COD_DISABLED. Flip to "true" and
# restart the backend to accept cash again (the customer app also needs its
# cash option re-enabled in checkout_screen.dart's _PaymentSelector).
COD_ENABLED=false

# ── Optional: MoMo / Stripe — leave empty to keep disabled ────────────────────
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
