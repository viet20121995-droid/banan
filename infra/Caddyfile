# Banan all-in-one on one server (BizFly). Caddy auto-provisions Let's Encrypt
# certs for all 4 hostnames and:
#   - proxies the API to the backend container
#   - serves the 3 Flutter web builds as static SPAs
#
# Set BASE_DOMAIN in infra/.env.prod (e.g. banan.com). DNS: point @, www,
# api, merchant, kitchen A-records at this server's public IP.

# ── Flutter SPA serving + cache policy ────────────────────────────────────────
# Flutter web does NOT content-hash main.dart.js / the service worker, so without
# an explicit no-cache the browser keeps serving a STALE build after every deploy
# (this is why "deploy had no effect"). Force-revalidate the entry files (the
# Etag still yields cheap 304s when unchanged); the content-hashed assets under
# assets/ + canvaskit/ keep their normal long caching.
(flutter_spa) {
	encode gzip zstd
	@entry path /index.html /flutter_service_worker.js /flutter_bootstrap.js /version.json /main.dart.js /manifest.json
	header @entry Cache-Control "no-cache, must-revalidate"
	# SPA fallback — deep links (/faq, /product/..) served by index.html.
	try_files {path} /index.html
	file_server
}

# ── API ───────────────────────────────────────────────────────────────────────
api.{$BASE_DOMAIN} {
	encode gzip zstd
	reverse_proxy backend:3000
}

# ── Customer web (root + www) ─────────────────────────────────────────────────
{$BASE_DOMAIN}, www.{$BASE_DOMAIN} {
	root * /srv/customer
	import flutter_spa
}

# ── Merchant web ──────────────────────────────────────────────────────────────
merchant.{$BASE_DOMAIN} {
	root * /srv/merchant
	import flutter_spa
}

# ── Kitchen web ───────────────────────────────────────────────────────────────
kitchen.{$BASE_DOMAIN} {
	root * /srv/kitchen
	import flutter_spa
}
